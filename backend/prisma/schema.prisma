generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Player {
  id        String   @id @default(uuid())
  nickname  String
  avatar    String?
  createdAt DateTime @default(now())

  rooms     RoomPlayer[]
  answers   Answer[]
}

model Room {
  id             String     @id @default(uuid())
  code           String     @unique
  status         RoomStatus @default(WAITING)
  hostId         String
  currentRoundId String?
  createdAt      DateTime   @default(now())

  players        RoomPlayer[]
  rounds         Round[]
}

model RoomPlayer {
  id        String   @id @default(uuid())
  roomId    String
  playerId  String
  score     Int      @default(0)
  isHost    Boolean  @default(false)
  joinedAt  DateTime @default(now())

  room      Room     @relation(fields: [roomId], references: [id])
  player    Player   @relation(fields: [playerId], references: [id])

  @@unique([roomId, playerId])
}

model Round {
  id        String      @id @default(uuid())
  roomId    String
  letter    String
  status    RoundStatus @default(RUNNING)
  startedAt DateTime    @default(now())
  endedAt   DateTime?

  room      Room        @relation(fields: [roomId], references: [id])
  answers   Answer[]
}

model Answer {
  id        String   @id @default(uuid())
  roundId   String
  playerId  String
  category  String
  value     String
  score     Int      @default(0)

  round     Round    @relation(fields: [roundId], references: [id])
  player    Player   @relation(fields: [playerId], references: [id])

  @@unique([roundId, playerId, category])
}

enum RoomStatus {
  WAITING
  PLAYING
  FINISHED
}

enum RoundStatus {
  RUNNING
  FINISHED
}
